# ── API Keys ──────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Model config ───────────────────────────────────────────────
# Stable Gemini 2.5 Flash model string
GEMINI_MODEL=gemini-2.5-flash

# ── ChromaDB ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Research config ────────────────────────────────────────────
MAX_SEARCH_RESULTS=8
MAX_RETRY_LOOPS=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100
